<Window x:Class="DPlayer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DPlayer.App"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        mc:Ignorable="d"
        Title="DPlayer" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e"
        Icon="Dplayer.ico"
        PreviewMouseMove="MainWindow_MouseMove">
    <Window.Resources />

    <Grid x:Name="RootGrid">
        <Grid.ContextMenu>
            <ContextMenu x:Name="PlayerContextMenu" Opened="PlayerContextMenu_Opened">
                <MenuItem Header="Open File..." Click="OpenFileButton_Click" />
                <MenuItem Header="Open URL..." Click="OpenUrlButton_Click" />
                <Separator />
                <MenuItem Header="Play / Pause" Click="PlayPauseButton_Click" />
                <MenuItem Header="Stop" Click="StopButton_Click" />
                <Separator />
                <MenuItem Header="Playback Speed">
                    <MenuItem Header="0.5x" Tag="0.5" Click="ContextMenuSpeed_Click" />
                    <MenuItem Header="0.75x" Tag="0.75" Click="ContextMenuSpeed_Click" />
                    <MenuItem Header="1.0x" Tag="1.0" Click="ContextMenuSpeed_Click" />
                    <MenuItem Header="1.25x" Tag="1.25" Click="ContextMenuSpeed_Click" />
                    <MenuItem Header="1.5x" Tag="1.5" Click="ContextMenuSpeed_Click" />
                    <MenuItem Header="2.0x" Tag="2.0" Click="ContextMenuSpeed_Click" />
                </MenuItem>
                <MenuItem Header="Volume">
                    <MenuItem Header="Mute / Unmute" Click="MuteButton_Click" />
                    <Separator />
                    <MenuItem Header="25%" Tag="25" Click="ContextMenuVolume_Click" />
                    <MenuItem Header="50%" Tag="50" Click="ContextMenuVolume_Click" />
                    <MenuItem Header="75%" Tag="75" Click="ContextMenuVolume_Click" />
                    <MenuItem Header="100%" Tag="100" Click="ContextMenuVolume_Click" />
                </MenuItem>
                <MenuItem x:Name="SubtitlesMenuItem" Header="Subtitles">
                    <MenuItem Header="None" Tag="-1" Click="ContextMenuSubtitle_Click" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Toggle Fullscreen" Click="FullScreenButton_Click" />
            </ContextMenu>
        </Grid.ContextMenu>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="ControlsRow" Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Video Player Area -->
        <Grid Grid.Row="0" Background="#000000">
            <vlc:VideoView x:Name="VideoView" Visibility="Collapsed">
                <!-- VideoOverlayGrid floats on top of native rendering to capture mouse events -->
                <Grid x:Name="VideoOverlayGrid" Background="#01000000" MouseMove="MainWindow_MouseMove">
                    <!-- Custom Fullscreen Title Bar Overlay (replaces native title bar to avoid WindowStyle flicker) -->
                    <Border x:Name="TitleBarOverlay"
                            VerticalAlignment="Top"
                            Visibility="Collapsed"
                            Panel.ZIndex="10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#CC000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Height="38">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Title text -->
                            <TextBlock x:Name="OverlayTitleText"
                                       Grid.Column="0"
                                       Foreground="White"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       TextTrimming="CharacterEllipsis"
                                       Opacity="0.9"/>
                            <!-- Window control buttons -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch">
                                <Button x:Name="OverlayMinimizeButton"
                                        Content="─"
                                        Width="46" Height="38"
                                        FontSize="10"
                                        Background="Transparent" Foreground="White"
                                        BorderBrush="Transparent"
                                        Click="OverlayMinimize_Click"
                                        Cursor="Hand"/>
                                <Button x:Name="OverlayRestoreButton"
                                        Content="⧉"
                                        Width="46" Height="38"
                                        FontSize="11"
                                        Background="Transparent" Foreground="White"
                                        BorderBrush="Transparent"
                                        Click="OverlayRestore_Click"
                                        Cursor="Hand"/>
                                <Button x:Name="OverlayCloseButton"
                                        Content="✕"
                                        Width="46" Height="38"
                                        FontSize="11"
                                        Background="Transparent" Foreground="White"
                                        BorderBrush="Transparent"
                                        Click="OverlayClose_Click"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </vlc:VideoView>
            <StackPanel x:Name="NoMediaPanel" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center"
                        Visibility="Visible">
                <Image Source="Dplayerlogo.png" 
                       Width="120" 
                       Height="120" 
                       Margin="0,0,0,15"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="DPlayer" 
                           FontSize="32" 
                           FontWeight="Bold"
                           Foreground="White" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>
                <TextBlock Text="No media loaded" 
                           FontSize="14" 
                           Foreground="#888888" 
                           HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            Margin="0,25,0,0">
                    <Button x:Name="OpenFileButton" 
                            Content="Open File" 
                            Width="120" 
                            Height="35" 
                            Margin="5"
                            Click="OpenFileButton_Click"
                            Background="#3a3a3a" 
                            Foreground="White"
                            BorderBrush="#555555"
                            Cursor="Hand"/>
                    <Button x:Name="OpenUrlButton" 
                            Content="Open URL" 
                            Width="120" 
                            Height="35" 
                            Margin="5"
                            Click="OpenUrlButton_Click"
                            Background="#3a3a3a" 
                            Foreground="White"
                            BorderBrush="#555555"
                            Cursor="Hand"/>
                    <Button x:Name="LibraryButton" 
                            Content="Library" 
                            Width="120" 
                            Height="35" 
                            Margin="5"
                            Click="LibraryButton_Click"
                            Background="#3a3a3a" 
                            Foreground="White"
                            BorderBrush="#555555"
                            Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Playback Controls (normal mode: Row 1; fullscreen: overlaid at bottom via VerticalAlignment) -->
        <Grid x:Name="PlaybackControls" Grid.Row="1" Background="#2d2d2d">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Playback Buttons -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="StopButton" 
                        Content="⏹" 
                        Width="40" 
                        Height="30" 
                        Margin="0,0,5,0"
                        Click="StopButton_Click"
                        Background="Transparent" 
                        Foreground="White"
                        BorderBrush="Transparent"
                        FontSize="16"
                        Cursor="Hand"/>
                <Button x:Name="PreviousButton" 
                        Content="⏮" 
                        Width="40" 
                        Height="30" 
                        Margin="0,0,5,0"
                        Click="PreviousButton_Click"
                        Background="Transparent" 
                        Foreground="White"
                        BorderBrush="Transparent"
                        FontSize="16"
                        Cursor="Hand"/>
                <Button x:Name="PlayPauseButton" 
                        Content="▶" 
                        Width="45" 
                        Height="35" 
                        Margin="0,0,5,0"
                        Click="PlayPauseButton_Click"
                        Background="#0078d4" 
                        Foreground="White"
                        BorderBrush="Transparent"
                        FontSize="18"
                        Cursor="Hand"/>
                <Button x:Name="NextButton" 
                        Content="⏭" 
                        Width="40" 
                        Height="30" 
                        Margin="0,0,5,0"
                        Click="NextButton_Click"
                        Background="Transparent" 
                        Foreground="White"
                        BorderBrush="Transparent"
                        FontSize="16"
                        Cursor="Hand"/>
            </StackPanel>

            <!-- Progress Bar and Time -->
            <StackPanel x:Name="ProgressTimePanel" Grid.Column="1" VerticalAlignment="Center" Margin="10,0" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" 
                               x:Name="CurrentTimeText" 
                               Text="00:00" 
                               Foreground="White" 
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <Slider Grid.Column="1" 
                            x:Name="ProgressSlider" 
                            Style="{StaticResource RoundedSliderStyle}"
                            Minimum="0" 
                            Maximum="100" 
                            Value="0"
                            VerticalAlignment="Center"
                            PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseLeftButtonUp"
                            Visibility="Visible"/>
                    <TextBlock Grid.Column="2" 
                               x:Name="TotalTimeText" 
                               Text="00:00" 
                               Foreground="White" 
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- Volume and Speed Controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="SpeedText" 
                           Text="1.0x" 
                           Foreground="White" 
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,5,0"/>
                <ComboBox x:Name="SpeedComboBox" 
                          Width="60" 
                          Height="25" 
                          SelectionChanged="SpeedComboBox_SelectionChanged"
                          Background="#3a3a3a" 
                          Foreground="White"
                          BorderBrush="#555555">
                    <ComboBoxItem Content="0.5x" Tag="0.5"/>
                    <ComboBoxItem Content="0.75x" Tag="0.75"/>
                    <ComboBoxItem Content="1.0x" Tag="1.0" IsSelected="True"/>
                    <ComboBoxItem Content="1.25x" Tag="1.25"/>
                    <ComboBoxItem Content="1.5x" Tag="1.5"/>
                    <ComboBoxItem Content="2.0x" Tag="2.0"/>
                </ComboBox>
                <Button x:Name="MuteButton" 
                        Content="🔊" 
                        Width="35" 
                        Height="30" 
                        Margin="10,0,5,0"
                        Click="MuteButton_Click"
                        Background="Transparent" 
                        Foreground="White"
                        BorderBrush="Transparent"
                        FontSize="14"
                        Cursor="Hand"/>
                <Slider x:Name="VolumeSlider" 
                        Style="{StaticResource RoundedSliderStyle}"
                        Width="80" 
                        Minimum="0" 
                        Maximum="100" 
                        Value="100"
                        VerticalAlignment="Center"
                        ValueChanged="VolumeSlider_ValueChanged"/>
                <Button x:Name="FullScreenButton" 
                        Content="⛶" 
                        Width="35" 
                        Height="30" 
                        Margin="10,0,0,0"
                        Click="FullScreenButton_Click"
                        Background="Transparent" 
                        Foreground="White"
                        BorderBrush="Transparent"
                        FontSize="14"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
