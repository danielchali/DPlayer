<Window x:Class="DPlayer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:conv="clr-namespace:DPlayer.App.Converters"
        Style="{StaticResource DPlayerWindowStyle}"
        Title="{Binding Title}"
        Height="900" Width="1600"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/DPlayer;component/Assets/Dplayer.ico"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        KeyDown="Window_KeyDown"
        StateChanged="Window_StateChanged"
        PreviewDragOver="Window_PreviewDragOver"
        Drop="Window_Drop">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:PlaybackStateToIconConverter x:Key="PlayIcon"/>
        <conv:MuteStateToIconConverter x:Key="MuteIcon"/>
        <conv:TimeSpanToStringConverter x:Key="TimeFormat"/>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="{DynamicResource BackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Left Sidebar Column -->
                <ColumnDefinition Width="230"/>
                <!-- Main Area Column -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Column 0: Left Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo Area -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                    <Grid Margin="0,0,10,0">
                        <Path Data="M 2,2 L 18,10 L 2,18 Z" Fill="#EC4899" Opacity="0.5" Width="20" Height="20">
                            <Path.Effect>
                                <BlurEffect Radius="6"/>
                            </Path.Effect>
                        </Path>
                        <Path Data="M 0,0 L 20,10 L 0,20 Z" Fill="{DynamicResource AccentGradientBrush}" Width="20" Height="20"/>
                    </Grid>
                    <TextBlock Text="DPlayer" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Menu ScrollViewer -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,10">
                        <!-- Section 1 Navigation -->
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" IsChecked="True" Checked="HomeNav_Checked" Content="&#xE80F;" Tag="Home"/>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="LibraryNav_Checked" Content="&#xE8F1;" Tag="Library"/>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="PlaylistNav_Checked" Content="&#xE8FD;" Tag="Playlist"/>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="FavoritesNav_Checked" Content="&#xE006;" Tag="Favorites"/>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="RecentNav_Checked" Content="&#xE823;" Tag="Recent"/>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="DownloadsNav_Checked" Content="&#xE896;" Tag="Downloads"/>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="WatchLaterNav_Checked" Content="&#xE916;" Tag="Watch Later"/>

                        <!-- Section 2: Stream From -->
                        <TextBlock Text="STREAM FROM" FontSize="9" FontWeight="Bold" Foreground="#4A4A6A" Margin="24,18,0,8"/>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="StreamNav_Checked" Content="&#xE714;" Tag="YouTube"/>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="StreamNav_Checked" Content="&#xE73E;" Tag="Google Drive"/>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="StreamNav_Checked" Content="&#xE716;" Tag="FTP / SFTP"/>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="StreamNav_Checked" Content="&#xE8F1;" Tag="NAS / SMB"/>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="StreamNav_Checked" Content="&#xE7B4;" Tag="IPTV / Online"/>

                        <!-- Section 3: Tools -->
                        <TextBlock Text="TOOLS" FontSize="9" FontWeight="Bold" Foreground="#4A4A6A" Margin="24,18,0,8"/>
                        <Grid>
                            <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="StudyModeNav_Checked" Content="&#xE7BE;" Tag="Study Mode"/>
                            <Border Background="#EC4899" CornerRadius="4" Padding="4,1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0" IsHitTestVisible="False">
                                <TextBlock Text="NEW" FontSize="7" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </Grid>
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}" GroupName="SidebarNav" Checked="SubtitlesNav_Checked" Content="&#xE7C2;" Tag="AI Subtitles"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Storage Info -->
                <Border Grid.Row="2" Background="#12122A" CornerRadius="12" Margin="14,10,14,20" Padding="12" BorderBrush="#1D1C3F" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#EC4899" Margin="0,0,8,4"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,6">
                            <TextBlock Text="Storage" FontSize="11" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="256 GB / 512 GB" FontSize="9" Foreground="#9393C5" Margin="0,1,0,0"/>
                        </StackPanel>

                        <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="4" Value="50" Minimum="0" Maximum="100"
                                     Background="#1D1C3F" Foreground="{DynamicResource AccentGradientBrush}">
                            <ProgressBar.Template>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Grid>
                                        <Border CornerRadius="2" Background="{TemplateBinding Background}"/>
                                        <Border CornerRadius="2" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left" Width="80"/>
                                    </Grid>
                                </ControlTemplate>
                            </ProgressBar.Template>
                        </ProgressBar>
                    </Grid>
                </Border>
                </Grid>
            </Border>

            <!-- Column 1: Main Content Column -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="TitleBarRow" Height="{StaticResource TitleBarHeight}"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="85"/>
                </Grid.RowDefinitions>

                <!-- Header / Custom Title bar -->
                <Border x:Name="TitleBar" Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search Bar -->
                        <Grid Grid.Column="0" HorizontalAlignment="Left" Width="360" VerticalAlignment="Center">
                            <Border Background="#12122A" CornerRadius="15" BorderBrush="#1D1C3F" BorderThickness="1" Height="30">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#9393C5" VerticalAlignment="Center" Margin="12,0,8,0"/>
                                    <TextBox x:Name="HeaderSearchBox" Grid.Column="1" Text="{Binding LibraryVm.SearchQuery, UpdateSourceTrigger=PropertyChanged}" KeyDown="HeaderSearchBox_KeyDown" Background="Transparent" BorderThickness="0" Foreground="White" CaretBrush="White" VerticalAlignment="Center" FontSize="11" VerticalContentAlignment="Center" BorderBrush="Transparent" Padding="0,0,4,0"/>
                                    <TextBlock Grid.Column="1" Text="Search videos, episodes, subtitles..." FontSize="11" Foreground="#4A4A6A" VerticalAlignment="Center" IsHitTestVisible="False" Margin="2,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ElementName=HeaderSearchBox, Path=Text}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ElementName=HeaderSearchBox, Path=Text}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="2" Text="Ctrl + K" FontSize="9" FontWeight="Bold" Foreground="#4A4A6A" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Right side tools -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource CleanButtonStyle}" Margin="0,0,14,0">
                                <Border CornerRadius="12" BorderThickness="1" BorderBrush="#F59E0B" Padding="10,4" Background="#15F59E0B">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#F59E0B" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Upgrade" FontSize="10" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Button>

                            <Button Style="{StaticResource IconButtonStyle}" Content="&#xE713;" Command="{Binding OpenSettingsCommand}" Margin="0,0,14,0"/>

                            <StackPanel Orientation="Horizontal" Margin="6,0,0,0">
                                <Button Style="{StaticResource TitleBarButtonStyle}" Content="&#xE921;" Click="Minimize_Click" ToolTip="Minimize"/>
                                <Button x:Name="MaximizeButton" Style="{StaticResource TitleBarButtonStyle}" Content="&#xE922;" Click="Maximize_Click" ToolTip="Maximize"/>
                                <Button Style="{StaticResource CloseButtonStyle}" Content="&#xE8BB;" Click="Close_Click" ToolTip="Close"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Center Content Area (Dashboard or Video Player) -->
                <Grid Grid.Row="1">
                    <!-- 1. Home Dashboard View -->
                    <Grid x:Name="DashboardView">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Home">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid Margin="20,0,20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>

                            <!-- Main Dashboard Content -->
                            <Grid Grid.Column="0" Margin="0,0,16,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Hero Banner -->
                                <Border Grid.Row="0" CornerRadius="16" Height="200" ClipToBounds="True" Margin="0,0,0,16">
                                    <Grid>
                                        <Border Background="#1A0D3C"/>
                                        <Ellipse Fill="#6F59FF" Width="300" Height="300" Opacity="0.15" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-80,-80"/>
                                        <Ellipse Fill="#EC4899" Width="350" Height="350" Opacity="0.15" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-100,0,0,0"/>

                                        <Grid Margin="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock FontSize="44" FontWeight="Black" Margin="0,0,0,4">
                                                    <Run Text="DP" Foreground="#EC4899"/><Run Text="layer" Foreground="#6F59FF"/>
                                                </TextBlock>
                                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8">
                                                    <Run Text="A " /><Run Text="Smart" Foreground="#6F59FF"/><Run Text=" Player for Your "/><Run Text="Videos" Foreground="#EC4899"/>
                                                </TextBlock>
                                                <TextBlock Text="Play. Understand. Learn." FontSize="14" Foreground="#9393C5"/>
                                            </StackPanel>

                                            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,24,0">
                                                <Ellipse Width="110" Height="110" Stroke="{DynamicResource AccentGradientBrush}" StrokeThickness="2" Opacity="0.6"/>
                                                <Border Width="80" Height="80" CornerRadius="40" Background="{DynamicResource AccentGradientBrush}">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#A855F7" BlurRadius="20" ShadowDepth="0" Opacity="0.8"/>
                                                    </Border.Effect>
                                                    <TextBlock Text="&#xF5B0;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Quick Action Cards -->
                                <Grid Grid.Row="1" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Open File -->
                                    <Button Grid.Column="0" Command="{Binding OpenFileCommand}" Style="{StaticResource CleanButtonStyle}">
                                        <Border Background="{DynamicResource OpenFileGradientBrush}" CornerRadius="16" Padding="18,20" Height="90">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="Open File" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                                    <TextBlock Text="Play local videos" FontSize="10" Foreground="#D0FFFFFF" Margin="0,1,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="2" Width="20" Height="20" CornerRadius="10" Background="#30FFFFFF" VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="7" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Button>

                                    <!-- Open URL -->
                                    <Button Grid.Column="2" Command="{Binding OpenUrlCommand}" Style="{StaticResource CleanButtonStyle}">
                                        <Border Background="{DynamicResource OpenUrlGradientBrush}" CornerRadius="16" Padding="18,20" Height="90">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="Open URL" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                                    <TextBlock Text="Stream from the web" FontSize="10" Foreground="#D0FFFFFF" Margin="0,1,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="2" Width="20" Height="20" CornerRadius="10" Background="#30FFFFFF" VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="7" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Button>

                                    <!-- Library -->
                                    <Button Grid.Column="4" Command="{Binding ToggleLibraryPanelCommand}" Style="{StaticResource CleanButtonStyle}">
                                        <Border Background="{DynamicResource LibraryGradientBrush}" CornerRadius="16" Padding="18,20" Height="90">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="Library" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                                    <TextBlock Text="Your media collection" FontSize="10" Foreground="#D0FFFFFF" Margin="0,1,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="2" Width="20" Height="20" CornerRadius="10" Background="#30FFFFFF" VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="7" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </Grid>

                                <!-- Continue Watching -->
                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Continue Watching &gt;" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ContinueWatchingItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="4"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.PlayContinueWatchingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource CleanButtonStyle}"
                                                        Margin="0,0,10,0" HorizontalAlignment="Stretch">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <Border Grid.Row="0" CornerRadius="10" ClipToBounds="True" Height="100">
                                                            <Grid>
                                                                <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                                                <Border Background="#20000000"/>
                                                                <Border Width="28" Height="28" CornerRadius="14" Background="#80000000" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <TextBlock Text="&#xF5B0;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                                                </Border>
                                                                <Border Background="#B0000000" CornerRadius="4" Padding="4,2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="6">
                                                                    <TextBlock Text="{Binding DurationText}" FontSize="8" Foreground="White" FontWeight="Bold"/>
                                                                </Border>
                                                            </Grid>
                                                        </Border>

                                                        <StackPanel Grid.Row="1" Margin="2,8,2,0">
                                                            <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Progress, StringFormat='{}{0}% watched'}" Foreground="#9393C5" FontSize="9" Margin="0,1,0,3"/>
                                                            <ProgressBar Value="{Binding Progress}" Style="{StaticResource CardProgressBarStyle}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>

                            <!-- Right Side AI panel -->
                            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,0,0,10">
                                    <!-- AI Subtitles -->
                                    <Border CornerRadius="14" Background="#12122A" BorderBrush="#1D1C3F" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="&#xE7C2;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#A855F7" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="AI Subtitles" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Find, generate or create live subtitles" FontSize="10" Foreground="#9393C5" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                            <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource CleanButtonStyle}" Command="{Binding OpenSubtitleSearchCommand}">
                                                <Border CornerRadius="12" Background="{DynamicResource AccentGradientBrush}" Padding="12,5" HorizontalAlignment="Left">
                                                    <TextBlock Text="Get Subtitles" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Button>

                                            <TextBlock Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="44" Foreground="#2A2A4E" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <!-- Study Mode -->
                                    <Border CornerRadius="14" Background="#12122A" BorderBrush="#1D1C3F" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="&#xE7BE;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#6F59FF" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Study Mode" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                <Border Background="#EC4899" CornerRadius="4" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="NEW" FontSize="7" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ask the video. Find answers. Save time." FontSize="10" Foreground="#9393C5" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                            <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource CleanButtonStyle}">
                                                <Border CornerRadius="12" Background="#6F59FF" Padding="12,5" HorizontalAlignment="Left">
                                                    <TextBlock Text="Start Study Mode" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Button>

                                            <TextBlock Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="44" Foreground="#2A2A4E" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <!-- Smart Features -->
                                    <Border CornerRadius="14" Background="#12122A" BorderBrush="#1D1C3F" BorderThickness="1" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Smart Features" FontSize="13" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="&#xE909;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#EC4899" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="AI Translations &amp; Dubbing" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    <TextBlock Text="Watch in any language" FontSize="8" Foreground="#9393C5"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#06B6D4" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="Smart Episode Detection" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    <TextBlock Text="Always in the right order" FontSize="8" Foreground="#9393C5"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#F59E0B" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="AI Summaries" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    <TextBlock Text="Summarize any video" FontSize="8" Foreground="#9393C5"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="&#xE814;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#A855F7" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="Timestamp Search" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    <TextBlock Text="Jump to what matters" FontSize="8" Foreground="#9393C5"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <TextBlock Text="&#xE8F2;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#3B82F6" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="Ask the Video" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    <TextBlock Text="Chat with your content" FontSize="8" Foreground="#9393C5"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Separator Background="#1D1C3F" Height="1" Margin="0,4,0,10"/>

                                            <TextBlock Text="See all features &gt;" FontSize="10" FontWeight="Bold" Foreground="#6F59FF" Cursor="Hand" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <!-- 2. Video Player View -->
                    <Grid x:Name="PlayerView">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Player">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Video Area -->
                            <Grid Grid.Column="0" Background="#000000">
                                <vlc:VideoView x:Name="VideoView" Background="#000000">
                                    <Grid x:Name="VideoOverlay"
                                          Background="#01000000"
                                          MouseMove="VideoArea_MouseMove"
                                          MouseLeftButtonDown="VideoArea_MouseLeftButtonDown">
                                        <Grid.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="Play / Pause" Command="{Binding TogglePlayPauseCommand}"/>
                                                <MenuItem Header="Open URL..." Command="{Binding OpenUrlCommand}"/>
                                                <Separator/>
                                                <MenuItem Header="Video">
                                                    <MenuItem Header="Brightness / Contrast / Saturation" Command="{Binding OpenSettingsCommand}"/>
                                                    <MenuItem Header="Aspect Ratio">
                                                        <MenuItem Header="Auto" Command="{Binding SetAspectRatioCommand}" CommandParameter="Auto"/>
                                                        <MenuItem Header="16:9" Command="{Binding SetAspectRatioCommand}" CommandParameter="Ratio16x9"/>
                                                        <MenuItem Header="4:3" Command="{Binding SetAspectRatioCommand}" CommandParameter="Ratio4x3"/>
                                                        <MenuItem Header="21:9" Command="{Binding SetAspectRatioCommand}" CommandParameter="Ratio21x9"/>
                                                        <MenuItem Header="Fill" Command="{Binding SetAspectRatioCommand}" CommandParameter="Fill"/>
                                                        <MenuItem Header="Stretch" Command="{Binding SetAspectRatioCommand}" CommandParameter="Stretch"/>
                                                    </MenuItem>
                                                    <MenuItem Header="Rotate Video" Command="{Binding OpenSettingsCommand}"/>
                                                    <MenuItem Header="Screenshot" Command="{Binding TakeScreenshotCommand}"/>
                                                    <MenuItem Header="Media Info" Command="{Binding ShowMediaInfoCommand}"/>
                                                </MenuItem>
                                                <MenuItem Header="Audio">
                                                    <MenuItem Header="{Binding SelectedAudioTrackText}" Command="{Binding CycleAudioTrackCommand}"/>
                                                    <MenuItem Header="Audio Tracks" ItemsSource="{Binding AudioTracks}">
                                                        <MenuItem.ItemContainerStyle>
                                                            <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                                <Setter Property="Header" Value="{Binding Label}"/>
                                                                <Setter Property="Command" Value="{Binding DataContext.SelectAudioTrackCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                                                                <Setter Property="CommandParameter" Value="{Binding Index}"/>
                                                            </Style>
                                                        </MenuItem.ItemContainerStyle>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <MenuItem Header="Audio Delay +50 ms" Command="{Binding AdjustAudioDelayCommand}" CommandParameter="50"/>
                                                    <MenuItem Header="Audio Delay -50 ms" Command="{Binding AdjustAudioDelayCommand}" CommandParameter="-50"/>
                                                    <MenuItem Header="Reset A/V Sync" Command="{Binding ResetAvSyncCommand}"/>
                                                    <Separator/>
                                                    <MenuItem Header="Audio Settings" Command="{Binding OpenSettingsCommand}"/>
                                                </MenuItem>
                                                <MenuItem Header="Subtitle">
                                                    <MenuItem Header="{Binding SelectedSubtitleTrackText}" Command="{Binding CycleSubtitleTrackCommand}"/>
                                                    <MenuItem Header="Subtitle Off" Command="{Binding SelectSubtitleTrackCommand}" CommandParameter="-1"/>
                                                    <MenuItem Header="Subtitle Tracks" ItemsSource="{Binding SubtitleTracks}">
                                                        <MenuItem.ItemContainerStyle>
                                                            <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                                <Setter Property="Header" Value="{Binding Label}"/>
                                                                <Setter Property="Command" Value="{Binding DataContext.SelectSubtitleTrackCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                                                                <Setter Property="CommandParameter" Value="{Binding Index}"/>
                                                            </Style>
                                                        </MenuItem.ItemContainerStyle>
                                                    </MenuItem>
                                                    <MenuItem Header="Search &amp; Download" Command="{Binding OpenSubtitleSearchCommand}"/>
                                                    <MenuItem Header="Load External..." Command="{Binding LoadSubtitleCommand}"/>
                                                    <Separator/>
                                                    <MenuItem Header="Subtitle Delay +50 ms" Command="{Binding AdjustSubtitleDelayCommand}" CommandParameter="50"/>
                                                    <MenuItem Header="Subtitle Delay -50 ms" Command="{Binding AdjustSubtitleDelayCommand}" CommandParameter="-50"/>
                                                    <MenuItem Header="Reset A/V Sync" Command="{Binding ResetAvSyncCommand}"/>
                                                </MenuItem>
                                                <MenuItem Header="Playback">
                                                    <MenuItem Header="0.25x" Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="0.25"/>
                                                    <MenuItem Header="0.5x" Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="0.5"/>
                                                    <MenuItem Header="1.0x" Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="1"/>
                                                    <MenuItem Header="1.5x" Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="1.5"/>
                                                    <MenuItem Header="2.0x" Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="2"/>
                                                    <MenuItem Header="4.0x" Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="4"/>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="AB Repeat">
                                                    <MenuItem Header="Set Point A" Command="{Binding SetAbPointACommand}"/>
                                                    <MenuItem Header="Set Point B" Command="{Binding SetAbPointBCommand}"/>
                                                    <MenuItem Header="Clear" Command="{Binding ClearAbRepeatCommand}"/>
                                                </MenuItem>
                                                <MenuItem Header="Fullscreen" Command="{Binding ToggleFullscreenCommand}"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>

                                        <!-- Drop overlay hint -->
                                        <Border Background="#80000000" Visibility="Collapsed" x:Name="DropOverlay">
                                            <TextBlock Text="Drop media or subtitle files here"
                                                       Foreground="{DynamicResource AccentLightBrush}"
                                                       FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Idle center mark -->
                                        <Border Background="#000000"
                                                Visibility="{Binding CurrentFileName, Converter={StaticResource BoolToVis}, ConverterParameter=inverse}">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="DPlayer" FontSize="29" FontWeight="Bold"
                                                           Foreground="#363636" HorizontalAlignment="Center"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                                    <Button Content="Open File" Style="{StaticResource KmPillButtonStyle}"
                                                            Command="{Binding OpenFileCommand}" Margin="0,0,8,0"/>
                                                    <Button Content="Open URL" Style="{StaticResource KmPillButtonStyle}"
                                                            Command="{Binding OpenUrlCommand}" Margin="0,0,8,0"/>
                                                    <Button Content="Library" Style="{StaticResource KmPillButtonStyle}"
                                                            Command="{Binding ToggleLibraryPanelCommand}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- On-screen display -->
                                        <Border Background="#B0000000"
                                                CornerRadius="6"
                                                Padding="18,10"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsOsdVisible, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding OsdText}"
                                                       Foreground="White"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </vlc:VideoView>
                            </Grid>

                            <!-- Side Panel (Playlist / Subtitles) -->
                            <Border Grid.Column="1" Width="{StaticResource SidePanelWidth}"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                                    Visibility="{Binding IsPlaylistPanelOpen, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Padding="12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock Text="Playlist" FontWeight="SemiBold" FontSize="14"/>
                                            <Button Content="&#xE711;" Style="{StaticResource IconButtonStyle}"
                                                    HorizontalAlignment="Right" Width="28" Height="28"
                                                    Command="{Binding TogglePlaylistPanelCommand}"/>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1" DataContext="{Binding PlaylistVm}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <WrapPanel Grid.Row="0" Margin="8">
                                            <Button Content="+" Style="{StaticResource AccentButtonStyle}"
                                                    Command="{Binding CreatePlaylistCommand}" Margin="0,0,4,0" Padding="10,4"/>
                                            <Button Content="Add" Style="{StaticResource TextButtonStyle}"
                                                    Command="{Binding AddFileCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                            <Button Content="Import" Style="{StaticResource TextButtonStyle}"
                                                    Command="{Binding ImportPlaylistCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                            <Button Content="Export" Style="{StaticResource TextButtonStyle}"
                                                    Command="{Binding ExportPlaylistCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                            <Button Content="Use" Style="{StaticResource TextButtonStyle}"
                                                    Command="{Binding ActivatePlaylistCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                            <Button Content="Up" Style="{StaticResource TextButtonStyle}"
                                                    Command="{Binding MoveSelectedUpCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                            <Button Content="Down" Style="{StaticResource TextButtonStyle}"
                                                    Command="{Binding MoveSelectedDownCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                            <Button Content="Remove" Style="{StaticResource TextButtonStyle}"
                                                    Command="{Binding RemoveEntryCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                            <Button Content="Clear" Style="{StaticResource TextButtonStyle}"
                                                    Command="{Binding ClearPlaylistCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                        </WrapPanel>

                                        <ComboBox Grid.Row="1" Style="{StaticResource DPlayerComboBoxStyle}"
                                                  ItemsSource="{Binding Playlists}"
                                                  SelectedItem="{Binding SelectedPlaylist}"
                                                  DisplayMemberPath="Name"
                                                  Margin="8,0,8,8"/>

                                        <ListBox Grid.Row="2" Style="{StaticResource DPlayerListBoxStyle}"
                                                 ItemContainerStyle="{StaticResource DPlayerListBoxItemStyle}"
                                                 ItemsSource="{Binding SelectedPlaylist.Items}"
                                                 SelectedItem="{Binding SelectedEntry}"
                                                 MouseDoubleClick="PlaylistItems_MouseDoubleClick"
                                                 Margin="4">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding FilePath}" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Side Panel (Library) -->
                            <Border Grid.Column="1" Width="{StaticResource SidePanelWidth}"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                                    Visibility="{Binding IsLibraryPanelOpen, Converter={StaticResource BoolToVis}}">
                                <Grid DataContext="{Binding LibraryVm}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Padding="12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock Text="Library" FontWeight="SemiBold" FontSize="14"/>
                                            <Button Content="&#xE711;" Style="{StaticResource IconButtonStyle}"
                                                    HorizontalAlignment="Right" Width="28" Height="28"
                                                    Command="{Binding DataContext.ToggleLibraryPanelCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1" Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Row="0" Grid.Column="0" Style="{StaticResource DPlayerTextBoxStyle}"
                                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Search indexed media"/>
                                        <Button Grid.Row="0" Grid.Column="1" Content="Search" Style="{StaticResource TextButtonStyle}"
                                                Command="{Binding SearchCommand}" Width="Auto" Padding="10,4" Margin="6,0,0,0"/>
                                        <Button Grid.Row="1" Grid.ColumnSpan="2" Content="Scan Folder" Style="{StaticResource AccentButtonStyle}"
                                                Command="{Binding ScanFolderCommand}" Margin="0,8,0,0"/>
                                    </Grid>

                                    <TabControl Grid.Row="2" Margin="4" Background="Transparent" BorderThickness="0">
                                        <TabItem Header="Results">
                                            <ListBox Style="{StaticResource DPlayerListBoxStyle}"
                                                     ItemContainerStyle="{StaticResource DPlayerListBoxItemStyle}"
                                                     ItemsSource="{Binding SearchResults}"
                                                     MouseDoubleClick="LibraryItems_MouseDoubleClick">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding FilePath}" FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </TabItem>
                                        <TabItem Header="Recent">
                                            <ListBox Style="{StaticResource DPlayerListBoxStyle}"
                                                     ItemContainerStyle="{StaticResource DPlayerListBoxItemStyle}"
                                                     ItemsSource="{Binding RecentFiles}"
                                                     MouseDoubleClick="LibraryItems_MouseDoubleClick">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding FilePath}" FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </TabItem>
                                        <TabItem Header="Favorites">
                                            <ListBox Style="{StaticResource DPlayerListBoxStyle}"
                                                     ItemContainerStyle="{StaticResource DPlayerListBoxItemStyle}"
                                                     ItemsSource="{Binding Favorites}"
                                                     MouseDoubleClick="LibraryItems_MouseDoubleClick">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding FilePath}" FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </TabItem>
                                        <TabItem Header="Later">
                                            <ListBox Style="{StaticResource DPlayerListBoxStyle}"
                                                     ItemContainerStyle="{StaticResource DPlayerListBoxItemStyle}"
                                                     ItemsSource="{Binding WatchLater}"
                                                     MouseDoubleClick="LibraryItems_MouseDoubleClick">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding FilePath}" FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </TabItem>
                                    </TabControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Bottom Playback Control Bar -->
                <Border Grid.Row="2" Background="#0A0A1E" BorderBrush="#1D1C3F" BorderThickness="0,1,0,0" Visibility="{Binding IsControlsVisible, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Seek slider spanning full width -->
                        <Grid Grid.Row="0" Height="14" Margin="20,0">
                            <Slider Style="{StaticResource SeekSliderStyle}"
                                    Minimum="0" Maximum="{Binding Duration.TotalSeconds}"
                                    Value="{Binding Position.TotalSeconds, Mode=OneWay}"
                                    PreviewMouseLeftButtonDown="SeekSlider_PreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp"
                                    PreviewKeyUp="SeekSlider_PreviewKeyUp"
                                    ValueChanged="SeekSlider_ValueChanged"/>
                        </Grid>

                        <!-- Playback Controls and Volume/Info -->
                        <Grid Grid.Row="1" Margin="20,0,20,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: Now Playing item preview card -->
                            <Grid Grid.Column="0" VerticalAlignment="Center">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentFileName}" Value="No media loaded">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Thumbnail preview -->
                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8" ClipToBounds="True" Background="#12122A" BorderBrush="#1D1C3F" BorderThickness="1" Margin="0,0,10,0">
                                    <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#EC4899" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding CurrentFileName}" Foreground="White" FontWeight="Bold" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="150" VerticalAlignment="Center"/>
                                        <TextBlock Text="&#xE006;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#EC4899" Margin="6,0,0,0" VerticalAlignment="Center" Cursor="Hand"/>
                                    </StackPanel>
                                    <TextBlock Text="Local file playback" FontSize="9" Foreground="#9393C5" Margin="0,1,0,3" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Position, Converter={StaticResource TimeFormat}}" Foreground="#9393C5" FontSize="9" FontFamily="{StaticResource MonoFont}"/>
                                        <TextBlock Text=" / " Foreground="#9393C5" FontSize="9"/>
                                        <TextBlock Text="{Binding Duration, Converter={StaticResource TimeFormat}}" Foreground="#9393C5" FontSize="9" FontFamily="{StaticResource MonoFont}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Center: Playback control buttons -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Style="{StaticResource IconButtonStyle}" Command="{Binding ToggleShuffleCommand}" ToolTip="Shuffle" Margin="0,0,12,0">
                                    <TextBlock Text="&#xE8B1;">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Opacity" Value="0.4"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsShuffle}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <Setter Property="Foreground" Value="#EC4899"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>

                                <Button Style="{StaticResource TransportButtonStyle}" Content="&#xE892;" Command="{Binding PlayPreviousCommand}" ToolTip="Previous" Margin="0,0,10,0"/>

                                <Button Style="{StaticResource CircularPlayButtonStyle}" Command="{Binding TogglePlayPauseCommand}" ToolTip="Play/Pause (Space)" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding PlaybackState, Converter={StaticResource PlayIcon}}" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White"/>
                                </Button>

                                <Button Style="{StaticResource TransportButtonStyle}" Content="&#xE893;" Command="{Binding PlayNextCommand}" ToolTip="Next" Margin="0,0,12,0"/>

                                <Button Style="{StaticResource IconButtonStyle}" Command="{Binding ToggleLoopCommand}" ToolTip="Loop">
                                    <TextBlock Text="&#xE8EE;">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Opacity" Value="0.4"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLooping}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <Setter Property="Foreground" Value="#6F59FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </StackPanel>

                            <!-- Right: Volume, speed, settings, fullscreen -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding PlaybackSpeedText}" Foreground="#9393C5" VerticalAlignment="Center" Margin="0,0,14,0" FontSize="11" FontWeight="SemiBold" Cursor="Hand" MouseLeftButtonUp="SpeedText_Click"/>

                                <Button Style="{StaticResource IconButtonStyle}" Content="&#xE7C2;" Command="{Binding ToggleSubtitlePanelCommand}" ToolTip="Toggle Subtitles" Margin="0,0,10,0"/>

                                <Button Style="{StaticResource IconButtonStyle}" Content="&#xE914;" Command="{Binding OpenSettingsCommand}" ToolTip="Picture in Picture / Video settings" Margin="0,0,10,0"/>

                                <Button Style="{StaticResource IconButtonStyle}" Content="{Binding IsMuted, Converter={StaticResource MuteIcon}}" Command="{Binding ToggleMuteCommand}" ToolTip="Mute (M)" Margin="0,0,6,0"/>

                                <Slider Style="{StaticResource VolumeSliderStyle}" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=TwoWay}" Margin="0,0,14,0"/>

                                <Button x:Name="FullscreenButton" Style="{StaticResource IconButtonStyle}" Content="&#xE740;" Command="{Binding ToggleFullscreenCommand}" ToolTip="Fullscreen (F)"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
