<Window x:Class="DPlayer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:conv="clr-namespace:DPlayer.App.Converters"
        Style="{StaticResource DPlayerWindowStyle}"
        Title="{Binding Title}"
        Height="720" Width="1280"
        MinHeight="480" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/DPlayer;component/Assets/dplayer.png"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        KeyDown="Window_KeyDown"
        StateChanged="Window_StateChanged"
        PreviewDragOver="Window_PreviewDragOver"
        Drop="Window_Drop">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:PlaybackStateToIconConverter x:Key="PlayIcon"/>
        <conv:MuteStateToIconConverter x:Key="MuteIcon"/>
        <conv:TimeSpanToStringConverter x:Key="TimeFormat"/>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="#080808"
            CornerRadius="0"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TitleBarRow" Height="{StaticResource TitleBarHeight}"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="#1D1D1D"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="7,0">
                        <Button ToolTip="Player Menu"
                                Click="PlayerMenu_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Cursor="Hand">
                            <TextBlock Text="DPlayer" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Button.ContextMenu>
                                <ContextMenu Background="{StaticResource SurfaceBrush}"
                                             DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             BorderBrush="{StaticResource BorderBrush}">
                                    <MenuItem Header="Open File..." Command="{Binding OpenFileCommand}"/>
                                    <MenuItem Header="Open URL..." Command="{Binding OpenUrlCommand}"/>
                                    <MenuItem Header="Open Folder..." Command="{Binding OpenFolderCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Library" Command="{Binding ToggleLibraryPanelCommand}"/>
                                    <MenuItem Header="Playlist" Command="{Binding TogglePlaylistPanelCommand}"/>
                                    <MenuItem Header="Subtitle Search" Command="{Binding OpenSubtitleSearchCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}"/>
                                    <MenuItem Header="Media Info" Command="{Binding ShowMediaInfoCommand}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="{Binding CurrentFileName}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center"
                               HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource TitleBarButtonStyle}" Content="&#xE921;"
                                Click="Minimize_Click" ToolTip="Minimize"/>
                        <Button x:Name="MaximizeButton" Style="{StaticResource TitleBarButtonStyle}" Content="&#xE922;"
                                Click="Maximize_Click" ToolTip="Maximize"/>
                        <Button Style="{StaticResource CloseButtonStyle}" Content="&#xE8BB;"
                                Click="Close_Click" ToolTip="Close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Video Area -->
                <Grid Grid.Column="0" Background="#000000"
                      MouseMove="VideoArea_MouseMove"
                      MouseLeftButtonDown="VideoArea_MouseLeftButtonDown">
                    <Grid.ContextMenu>
                        <ContextMenu Background="{StaticResource SurfaceBrush}"
                                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}">
                            <MenuItem Header="Play / Pause" Command="{Binding TogglePlayPauseCommand}"/>
                            <MenuItem Header="Open URL..." Command="{Binding OpenUrlCommand}"/>
                            <Separator/>
                            <MenuItem Header="Video">
                                <MenuItem Header="Brightness / Contrast / Saturation" Command="{Binding OpenSettingsCommand}"/>
                                <MenuItem Header="Aspect Ratio">
                                    <MenuItem Header="Auto" Command="{Binding SetAspectRatioCommand}" CommandParameter="Auto"/>
                                    <MenuItem Header="16:9" Command="{Binding SetAspectRatioCommand}" CommandParameter="Ratio16x9"/>
                                    <MenuItem Header="4:3" Command="{Binding SetAspectRatioCommand}" CommandParameter="Ratio4x3"/>
                                    <MenuItem Header="21:9" Command="{Binding SetAspectRatioCommand}" CommandParameter="Ratio21x9"/>
                                    <MenuItem Header="Fill" Command="{Binding SetAspectRatioCommand}" CommandParameter="Fill"/>
                                    <MenuItem Header="Stretch" Command="{Binding SetAspectRatioCommand}" CommandParameter="Stretch"/>
                                </MenuItem>
                                <MenuItem Header="Rotate Video" Command="{Binding OpenSettingsCommand}"/>
                                <MenuItem Header="Screenshot" Command="{Binding TakeScreenshotCommand}"/>
                                <MenuItem Header="Media Info" Command="{Binding ShowMediaInfoCommand}"/>
                            </MenuItem>
                            <MenuItem Header="Audio">
                                <MenuItem Header="{Binding SelectedAudioTrackText}" Command="{Binding CycleAudioTrackCommand}"/>
                                <MenuItem Header="Audio Tracks" ItemsSource="{Binding AudioTracks}">
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Header" Value="{Binding Label}"/>
                                            <Setter Property="Command" Value="{Binding DataContext.SelectAudioTrackCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                                            <Setter Property="CommandParameter" Value="{Binding Index}"/>
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Audio Delay +50 ms" Command="{Binding AdjustAudioDelayCommand}" CommandParameter="50"/>
                                <MenuItem Header="Audio Delay -50 ms" Command="{Binding AdjustAudioDelayCommand}" CommandParameter="-50"/>
                                <MenuItem Header="Reset A/V Sync" Command="{Binding ResetAvSyncCommand}"/>
                                <Separator/>
                                <MenuItem Header="Audio Settings" Command="{Binding OpenSettingsCommand}"/>
                            </MenuItem>
                            <MenuItem Header="Subtitle">
                                <MenuItem Header="{Binding SelectedSubtitleTrackText}" Command="{Binding CycleSubtitleTrackCommand}"/>
                                <MenuItem Header="Subtitle Off" Command="{Binding SelectSubtitleTrackCommand}" CommandParameter="-1"/>
                                <MenuItem Header="Subtitle Tracks" ItemsSource="{Binding SubtitleTracks}">
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Header" Value="{Binding Label}"/>
                                            <Setter Property="Command" Value="{Binding DataContext.SelectSubtitleTrackCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"/>
                                            <Setter Property="CommandParameter" Value="{Binding Index}"/>
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                                <MenuItem Header="Search &amp; Download" Command="{Binding OpenSubtitleSearchCommand}"/>
                                <MenuItem Header="Load External..." Command="{Binding LoadSubtitleCommand}"/>
                                <Separator/>
                                <MenuItem Header="Subtitle Delay +50 ms" Command="{Binding AdjustSubtitleDelayCommand}" CommandParameter="50"/>
                                <MenuItem Header="Subtitle Delay -50 ms" Command="{Binding AdjustSubtitleDelayCommand}" CommandParameter="-50"/>
                                <MenuItem Header="Reset A/V Sync" Command="{Binding ResetAvSyncCommand}"/>
                            </MenuItem>
                            <MenuItem Header="Playback">
                                <MenuItem Header="0.25x" Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="0.25"/>
                                <MenuItem Header="0.5x" Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="0.5"/>
                                <MenuItem Header="1.0x" Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="1"/>
                                <MenuItem Header="1.5x" Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="1.5"/>
                                <MenuItem Header="2.0x" Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="2"/>
                                <MenuItem Header="4.0x" Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="4"/>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="AB Repeat">
                                <MenuItem Header="Set Point A" Command="{Binding SetAbPointACommand}"/>
                                <MenuItem Header="Set Point B" Command="{Binding SetAbPointBCommand}"/>
                                <MenuItem Header="Clear" Command="{Binding ClearAbRepeatCommand}"/>
                            </MenuItem>
                            <MenuItem Header="Fullscreen" Command="{Binding ToggleFullscreenCommand}"/>
                        </ContextMenu>
                    </Grid.ContextMenu>
                    <vlc:VideoView x:Name="VideoView" />

                    <!-- Drop overlay hint -->
                    <Border Background="#80000000" Visibility="Collapsed" x:Name="DropOverlay">
                        <TextBlock Text="Drop media or subtitle files here"
                                   Foreground="{StaticResource AccentLightBrush}"
                                   FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Idle center mark -->
                    <Border Background="#000000"
                            Visibility="{Binding CurrentFileName, Converter={StaticResource BoolToVis}, ConverterParameter=inverse}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="DPlayer" FontSize="29" FontWeight="Bold"
                                       Foreground="#363636" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                <Button Content="Open File" Style="{StaticResource KmPillButtonStyle}"
                                        Command="{Binding OpenFileCommand}" Margin="0,0,8,0"/>
                                <Button Content="Open URL" Style="{StaticResource KmPillButtonStyle}"
                                        Command="{Binding OpenUrlCommand}" Margin="0,0,8,0"/>
                                <Button Content="Library" Style="{StaticResource KmPillButtonStyle}"
                                        Command="{Binding ToggleLibraryPanelCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- On-screen display -->
                    <Border Background="#B0000000"
                            CornerRadius="6"
                            Padding="18,10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsOsdVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding OsdText}"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                    </Border>
                </Grid>

                <!-- Side Panel (Playlist / Subtitles) -->
                <Border Grid.Column="1" Width="{StaticResource SidePanelWidth}"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0"
                        Visibility="{Binding IsPlaylistPanelOpen, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="12,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="Playlist" FontWeight="SemiBold" FontSize="14"/>
                                <Button Content="&#xE711;" Style="{StaticResource IconButtonStyle}"
                                        HorizontalAlignment="Right" Width="28" Height="28"
                                        Command="{Binding TogglePlaylistPanelCommand}"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" DataContext="{Binding PlaylistVm}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0" Margin="8">
                                <Button Content="+" Style="{StaticResource AccentButtonStyle}"
                                        Command="{Binding CreatePlaylistCommand}" Margin="0,0,4,0" Padding="10,4"/>
                                <Button Content="Add" Style="{StaticResource TextButtonStyle}"
                                        Command="{Binding AddFileCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                <Button Content="Import" Style="{StaticResource TextButtonStyle}"
                                        Command="{Binding ImportPlaylistCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                <Button Content="Export" Style="{StaticResource TextButtonStyle}"
                                        Command="{Binding ExportPlaylistCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                <Button Content="Use" Style="{StaticResource TextButtonStyle}"
                                        Command="{Binding ActivatePlaylistCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                <Button Content="Up" Style="{StaticResource TextButtonStyle}"
                                        Command="{Binding MoveSelectedUpCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                <Button Content="Down" Style="{StaticResource TextButtonStyle}"
                                        Command="{Binding MoveSelectedDownCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                <Button Content="Remove" Style="{StaticResource TextButtonStyle}"
                                        Command="{Binding RemoveEntryCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                                <Button Content="Clear" Style="{StaticResource TextButtonStyle}"
                                        Command="{Binding ClearPlaylistCommand}" Width="Auto" Padding="8,4" Margin="0,0,4,4"/>
                            </WrapPanel>

                            <ComboBox Grid.Row="1" Style="{StaticResource DPlayerComboBoxStyle}"
                                      ItemsSource="{Binding Playlists}"
                                      SelectedItem="{Binding SelectedPlaylist}"
                                      DisplayMemberPath="Name"
                                      Margin="8,0,8,8"/>

                            <ListBox Grid.Row="2" Style="{StaticResource DPlayerListBoxStyle}"
                                     ItemContainerStyle="{StaticResource DPlayerListBoxItemStyle}"
                                     ItemsSource="{Binding SelectedPlaylist.Items}"
                                     SelectedItem="{Binding SelectedEntry}"
                                     MouseDoubleClick="PlaylistItems_MouseDoubleClick"
                                     Margin="4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding FilePath}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Side Panel (Library) -->
                <Border Grid.Column="1" Width="{StaticResource SidePanelWidth}"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0"
                        Visibility="{Binding IsLibraryPanelOpen, Converter={StaticResource BoolToVis}}">
                    <Grid DataContext="{Binding LibraryVm}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="12,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="Library" FontWeight="SemiBold" FontSize="14"/>
                                <Button Content="&#xE711;" Style="{StaticResource IconButtonStyle}"
                                        HorizontalAlignment="Right" Width="28" Height="28"
                                        Command="{Binding DataContext.ToggleLibraryPanelCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Row="0" Grid.Column="0" Style="{StaticResource DPlayerTextBoxStyle}"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Search indexed media"/>
                            <Button Grid.Row="0" Grid.Column="1" Content="Search" Style="{StaticResource TextButtonStyle}"
                                    Command="{Binding SearchCommand}" Width="Auto" Padding="10,4" Margin="6,0,0,0"/>
                            <Button Grid.Row="1" Grid.ColumnSpan="2" Content="Scan Folder" Style="{StaticResource AccentButtonStyle}"
                                    Command="{Binding ScanFolderCommand}" Margin="0,8,0,0"/>
                        </Grid>

                        <TabControl Grid.Row="2" Margin="4" Background="Transparent" BorderThickness="0">
                            <TabItem Header="Results">
                                <ListBox Style="{StaticResource DPlayerListBoxStyle}"
                                         ItemContainerStyle="{StaticResource DPlayerListBoxItemStyle}"
                                         ItemsSource="{Binding SearchResults}"
                                         MouseDoubleClick="LibraryItems_MouseDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FilePath}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </TabItem>
                            <TabItem Header="Recent">
                                <ListBox Style="{StaticResource DPlayerListBoxStyle}"
                                         ItemContainerStyle="{StaticResource DPlayerListBoxItemStyle}"
                                         ItemsSource="{Binding RecentFiles}"
                                         MouseDoubleClick="LibraryItems_MouseDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FilePath}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </TabItem>
                            <TabItem Header="Favorites">
                                <ListBox Style="{StaticResource DPlayerListBoxStyle}"
                                         ItemContainerStyle="{StaticResource DPlayerListBoxItemStyle}"
                                         ItemsSource="{Binding Favorites}"
                                         MouseDoubleClick="LibraryItems_MouseDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FilePath}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </TabItem>
                            <TabItem Header="Later">
                                <ListBox Style="{StaticResource DPlayerListBoxStyle}"
                                         ItemContainerStyle="{StaticResource DPlayerListBoxItemStyle}"
                                         ItemsSource="{Binding WatchLater}"
                                         MouseDoubleClick="LibraryItems_MouseDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FilePath}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- Control Bar -->
            <Border Grid.Row="2" Background="#1B1B1B"
                    BorderBrush="#292929" BorderThickness="0,1,0,0"
                    Padding="8,5"
                    Visibility="{Binding IsControlsVisible, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Seek Bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Position, Converter={StaticResource TimeFormat}}"
                                   Foreground="#858585" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0" FontFamily="{StaticResource MonoFont}"/>
                        <Slider Grid.Column="1" Style="{StaticResource SeekSliderStyle}"
                                Minimum="0" Maximum="{Binding Duration.TotalSeconds}"
                                Value="{Binding Position.TotalSeconds, Mode=OneWay}"
                                PreviewMouseLeftButtonDown="SeekSlider_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp"
                                PreviewKeyUp="SeekSlider_PreviewKeyUp"
                                ValueChanged="SeekSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" Text="{Binding Duration, Converter={StaticResource TimeFormat}}"
                                   Foreground="#858585" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0" FontFamily="{StaticResource MonoFont}"/>
                    </Grid>

                    <!-- Transport Controls -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left controls -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource IconButtonStyle}" Content="&#xE8E5;"
                                    Command="{Binding OpenFileCommand}" ToolTip="Open File (Ctrl+O)"/>
                            <Button Style="{StaticResource IconButtonStyle}" Content="&#xE71B;"
                                    Command="{Binding OpenUrlCommand}" ToolTip="Open URL (Ctrl+U)"/>
                            <Button Style="{StaticResource IconButtonStyle}" Content="&#xE721;"
                                    Command="{Binding OpenSubtitleSearchCommand}" ToolTip="Search Subtitles (Ctrl+S)"/>
                            <Button Style="{StaticResource IconButtonStyle}" Content="&#xE8FD;"
                                    Command="{Binding TogglePlaylistPanelCommand}" ToolTip="Playlist (L)"/>
                            <Button Style="{StaticResource IconButtonStyle}" Content="&#xE80F;"
                                    Command="{Binding ToggleLibraryPanelCommand}" ToolTip="Library"/>
                            <TextBlock Text="{Binding PlaybackSpeedText}" Foreground="#858585"
                                       VerticalAlignment="Center" Margin="7,0" FontSize="11" FontWeight="SemiBold"
                                       Cursor="Hand" MouseLeftButtonUp="SpeedText_Click"/>
                        </StackPanel>

                        <!-- Center transport -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Style="{StaticResource TransportButtonStyle}" Content="&#xE8E5;"
                                    Command="{Binding OpenFileCommand}" ToolTip="Open File"/>
                            <Button Style="{StaticResource TransportButtonStyle}" Content="&#xE892;"
                                    Command="{Binding PlayPreviousCommand}" ToolTip="Previous"/>
                            <Button Style="{StaticResource PlayButtonStyle}"
                                    Content="{Binding PlaybackState, Converter={StaticResource PlayIcon}}"
                                    FontFamily="Segoe MDL2 Assets" FontSize="16"
                                    Command="{Binding TogglePlayPauseCommand}" ToolTip="Play/Pause (Space)"/>
                            <Button Style="{StaticResource TransportButtonStyle}" Content="&#xE893;"
                                    Command="{Binding PlayNextCommand}" ToolTip="Next"/>
                            <Button Style="{StaticResource TransportButtonStyle}" Content="&#xE71A;"
                                    Command="{Binding StopCommand}" ToolTip="Stop"/>
                        </StackPanel>

                        <!-- Right controls -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Style="{StaticResource IconButtonStyle}"
                                    Command="{Binding ToggleShuffleCommand}" ToolTip="Shuffle">
                                <TextBlock Text="&#xE8B1;">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Opacity" Value="0.4"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsShuffle}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}"
                                    Command="{Binding ToggleLoopCommand}" ToolTip="Loop">
                                <TextBlock Text="&#xE8EE;"/>
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" Content="&#xE7B3;"
                                    Command="{Binding TakeScreenshotCommand}" ToolTip="Screenshot"/>
                            <Button x:Name="FullscreenButton" Style="{StaticResource IconButtonStyle}" Content="&#xE740;"
                                    Command="{Binding ToggleFullscreenCommand}" ToolTip="Fullscreen (F)"/>
                            <Button Style="{StaticResource IconButtonStyle}"
                                    Content="{Binding IsMuted, Converter={StaticResource MuteIcon}}"
                                    Command="{Binding ToggleMuteCommand}" ToolTip="Mute (M)"/>
                            <Slider Style="{StaticResource VolumeSliderStyle}" Minimum="0" Maximum="100"
                                    Value="{Binding Volume, Mode=TwoWay}" Margin="4,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
