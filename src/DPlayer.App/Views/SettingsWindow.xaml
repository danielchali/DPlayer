<Window x:Class="DPlayer.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource DPlayerWindowStyle}"
        Title="Settings" Height="560" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Theme -->
                <TextBlock Text="Appearance" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Theme" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" Style="{StaticResource DPlayerComboBoxStyle}"
                              ItemsSource="{Binding AvailableThemes}"
                              SelectedItem="{Binding SelectedTheme}"/>
                </Grid>

                <!-- Playback -->
                <TextBlock Text="Playback" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                <CheckBox Content="Hardware acceleration (NVDEC / AMF / Quick Sync)"
                          IsChecked="{Binding HardwareAcceleration}" Margin="0,4"/>
                <CheckBox Content="Resume playback position" IsChecked="{Binding ResumePlayback}" Margin="0,4"/>
                <CheckBox Content="Shuffle playlist" IsChecked="{Binding ShufflePlaylist}" Margin="0,4"/>
                <CheckBox Content="Loop playlist" IsChecked="{Binding LoopPlaylist}" Margin="0,4,0,16"/>

                <!-- Subtitles -->
                <TextBlock Text="Subtitles" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                <CheckBox Content="Auto-download subtitles" IsChecked="{Binding AutoDownloadSubtitles}" Margin="0,4"/>
                <Grid Margin="0,8,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Default language" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" Style="{StaticResource DPlayerComboBoxStyle}"
                              ItemsSource="{Binding LanguageCodes}"
                              SelectedItem="{Binding DefaultSubtitleLanguage}"/>
                </Grid>

                <!-- OpenSubtitles API -->
                <TextBlock Text="OpenSubtitles API" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="API Key" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Style="{StaticResource DPlayerTextBoxStyle}"
                             Text="{Binding OpenSubtitlesApiKey, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Username" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Style="{StaticResource DPlayerTextBoxStyle}"
                             Text="{Binding OpenSubtitlesUsername, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Password" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Style="{StaticResource DPlayerTextBoxStyle}"
                             Text="{Binding OpenSubtitlesPassword, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <!-- Audio -->
                <TextBlock Text="Audio" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                <CheckBox Content="Audio normalization" IsChecked="{Binding AudioNormalization}" Margin="0,4"/>
                <CheckBox Content="Surround sound simulation" IsChecked="{Binding SurroundSimulation}" Margin="0,4"/>
                <Grid Margin="0,8,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Bass boost" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="10" Value="{Binding BassBoost}"/>
                </Grid>

                <!-- Updates -->
                <TextBlock Text="Updates" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                <CheckBox Content="Check for updates automatically" IsChecked="{Binding CheckForUpdates}" Margin="0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Check Now" Style="{StaticResource AccentButtonStyle}"
                            Command="{Binding CheckUpdatesCommand}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding UpdateStatus}" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Style="{StaticResource AccentButtonStyle}"
                    Command="{Binding SaveCommand}" Margin="0,0,8,0"/>
            <Button Content="Close" Style="{StaticResource IconButtonStyle}"
                    Click="Close_Click" Width="Auto" Padding="16,8"/>
        </StackPanel>
    </Grid>
</Window>
