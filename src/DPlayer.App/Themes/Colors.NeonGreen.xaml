<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="AccentColor">#39FF14</Color>
    <Color x:Key="AccentLightColor">#7FFF00</Color>
    <Color x:Key="AccentDarkColor">#32CD32</Color>
    <Color x:Key="BackgroundColor">#0A0A0A</Color>
    <Color x:Key="SurfaceColor">#141414</Color>
    <Color x:Key="SurfaceElevatedColor">#1A1A1A</Color>
    <Color x:Key="BorderColor">#2A2A2A</Color>
    <Color x:Key="TextPrimaryColor">#E8FFE8</Color>
    <Color x:Key="TextSecondaryColor">#8F9F8F</Color>
    <Color x:Key="DangerColor">#FF4444</Color>
    <Color x:Key="WarningColor">#FFCC00</Color>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#39FF14" Offset="0"/>
        <GradientStop Color="#7FFF00" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="TitleBarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#141414" Offset="0"/>
        <GradientStop Color="#0A0A0A" Offset="1"/>
    </LinearGradientBrush>

    <!-- Dashboard card gradient brushes -->
    <LinearGradientBrush x:Key="OpenFileGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1E5631" Offset="0"/>
        <GradientStop Color="#32CD32" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OpenUrlGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0D9488" Offset="0"/>
        <GradientStop Color="#39FF14" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LibraryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#22C55E" Offset="0"/>
        <GradientStop Color="#84CC16" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarSelectionGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#32CD32" Offset="0"/>
        <GradientStop Color="#7FFF00" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
