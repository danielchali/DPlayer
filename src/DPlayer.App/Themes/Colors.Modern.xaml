<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DPlayer Modern Theme - Vibrant Dark Blue with Neon Accents -->
    
    <!-- Primary Colors -->
    <Color x:Key="BackgroundColor">#0A0E27</Color>
    <Color x:Key="SurfaceColor">#0F1428</Color>
    <Color x:Key="SurfaceElevatedColor">#1A2847</Color>
    <Color x:Key="BorderColor">#2A3F5F</Color>
    
    <!-- Accent Colors - Vibrant Neon -->
    <Color x:Key="AccentColor">#00D9FF</Color>
    <Color x:Key="AccentLightColor">#00FFFF</Color>
    <Color x:Key="AccentDarkColor">#0099CC</Color>
    <Color x:Key="PrimaryPinkColor">#FF1493</Color>
    <Color x:Key="OrangeColor">#FF6B35</Color>
    
    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#8B949E</Color>
    <Color x:Key="TextTertiaryColor">#6B7280</Color>
    
    <!-- Status Colors -->
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    
    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryPinkBrush" Color="{StaticResource PrimaryPinkColor}"/>
    <SolidColorBrush x:Key="OrangeBrush" Color="{StaticResource OrangeColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    
    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF1493" Offset="0"/>
        <GradientStop Color="#00D9FF" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="TitleBarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A1F3A" Offset="0"/>
        <GradientStop Color="#0F1428" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="OrangeGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF6B35" Offset="0"/>
        <GradientStop Color="#FF8C42" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="CyanGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00D9FF" Offset="0"/>
        <GradientStop Color="#00FFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Dashboard card gradient brushes -->
    <LinearGradientBrush x:Key="OpenFileGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0099CC" Offset="0"/>
        <GradientStop Color="#00FFFF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OpenUrlGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF1493" Offset="0"/>
        <GradientStop Color="#8B5CF6" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LibraryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF6B35" Offset="0"/>
        <GradientStop Color="#FFA500" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarSelectionGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF1493" Offset="0"/>
        <GradientStop Color="#00D9FF" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
